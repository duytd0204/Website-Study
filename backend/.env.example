# ============================================================
# CẤU HÌNH HỆ THỐNG QUẢN LÝ HỌC TẬP - ĐẠI HỌC THỦY LỢI
# ============================================================
# Sao chép file này thành .env và điền các giá trị thực tế

# --- Bảo mật ---
SECRET_KEY=tlu_secret_key_change_this_in_production_please_use_long_random_string
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Database ---
DATABASE_URL=sqlite:///./data/tlu.db

# ============================================================
#  AI - CẤU HÌNH TRỢ LÝ ẢO (CHATBOT)
# ============================================================
# Chọn nhà cung cấp cho Chatbot: "groq" hoặc "gemini"
#   - groq:   MIỄN PHÍ rộng rãi (~14.400 request/ngày), rất nhanh, KHÔNG đọc được ảnh
#   - gemini: 1.500 request/ngày, đọc được ảnh (cần cho OCR)
AI_PROVIDER=groq

# --- Groq (khuyến nghị cho Chatbot - miễn phí, nhanh) ---
# Lấy API key MIỄN PHÍ tại: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Google Gemini ---
# BẮT BUỘC cho tính năng Quét ảnh (OCR) vì Groq không đọc được ảnh.
# Cũng dùng cho Chatbot nếu đặt AI_PROVIDER=gemini.
# Lấy API key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ============================================================
#  SMTP Email (cho chức năng Quên mật khẩu)
# ============================================================
# Có thể dùng Gmail App Password. Để trống nếu chỉ chạy thử (OTP sẽ in ra console).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_NAME=TLU Learning Support

# --- Admin mặc định ---
DEFAULT_ADMIN_EMAIL=admin@tlu.edu.vn
DEFAULT_ADMIN_PASSWORD=Admin@123456
